# CLI Console Application (Phase 1-3)
FROM eclipse-temurin:21-jdk
WORKDIR /app

# Copy source, libs, and sample data
COPY src src
COPY lib lib
COPY sample_project.csv .

# Compile
RUN mkdir -p bin && \
    javac -cp "lib/postgresql-42.7.3.jar" -d bin \
      src/model/*.java src/calculator/*.java src/io/*.java src/db/*.java src/Main.java

# Run interactively
ENTRYPOINT ["java", "-cp", "bin:lib/postgresql-42.7.3.jar", "Main"]
